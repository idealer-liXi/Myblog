<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.idealer01.infrastructure.dao.IUserLevelDao">
    <resultMap id="dataMap" type="cn.idealer01.infrastructure.dao.po.UserLevel">
        <id column="id" property="id"/>
        <result column="level_id" property="levelId"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryLevelNameById" parameterType="java.lang.Integer" resultType="java.lang.String">
        select name from user_level where level_id = #{level_id}
    </select>
</mapper>
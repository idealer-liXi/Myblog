<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.idealer01.infrastructure.dao.IMusicDao">

    <resultMap id="dataMap" type="cn.idealer01.infrastructure.dao.po.MusicRecord">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="artist" property="artist"/>
        <result column="audio_url" property="audioUrl"/>
        <result column="cover_image" property="coverImage"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="enabled" property="enabled"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryAll" resultMap="dataMap">
        select *
        from music
        order by sort_order asc, id desc
    </select>

    <select id="queryEnabledList" resultMap="dataMap">
        select *
        from music
        where enabled = 1
        order by sort_order asc, id desc
    </select>

    <select id="queryById" parameterType="java.lang.Long" resultMap="dataMap">
        select *
        from music
        where id = #{id}
    </select>

    <insert id="insert" parameterType="cn.idealer01.infrastructure.dao.po.MusicRecord" useGeneratedKeys="true" keyProperty="id">
        insert into music(name, artist, audio_url, cover_image, sort_order, enabled)
        values (#{name}, #{artist}, #{audioUrl}, #{coverImage}, #{sortOrder}, #{enabled})
    </insert>

    <update id="update" parameterType="cn.idealer01.infrastructure.dao.po.MusicRecord">
        update music
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="artist != null">artist = #{artist},</if>
            <if test="audioUrl != null">audio_url = #{audioUrl},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="enabled != null">enabled = #{enabled},</if>
            update_time = CURRENT_TIMESTAMP
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from music where id = #{id}
    </delete>

</mapper>

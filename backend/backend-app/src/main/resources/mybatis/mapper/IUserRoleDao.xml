<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.idealer01.infrastructure.dao.IUserRoleDao">

    <resultMap id="dataMap" type="cn.idealer01.infrastructure.dao.po.UserRole">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="role_id" property="roleId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertUserRole" parameterType="cn.idealer01.infrastructure.dao.po.UserRole" useGeneratedKeys="true" keyProperty="id">
        insert into user_role(user_id, role_id)
        values (#{userId}, #{roleId})
    </insert>

    <select id="queryUserRoleByUserId" parameterType="java.lang.Long" resultMap="dataMap">
        select id, user_id, role_id, create_time, update_time
        from user_role
        where user_id = #{userId};
    </select>

</mapper>

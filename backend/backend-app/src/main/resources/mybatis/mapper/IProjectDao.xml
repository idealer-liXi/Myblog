<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.idealer01.infrastructure.dao.IProjectDao">

    <resultMap id="dataMap" type="cn.idealer01.infrastructure.dao.po.Project">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="tech_stack" property="techStack"/>
        <result column="project_url" property="projectUrl"/>
        <result column="github_url" property="githubUrl"/>
        <result column="preview_url" property="previewUrl"/>
        <result column="cover_image" property="coverImage"/>
        <result column="showcase_images" property="showcaseImages"/>
        <result column="status" property="status"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="start_date" property="startDate"/>
        <result column="end_date" property="endDate"/>
        <result column="is_public" property="isPublic"/>
        <result column="enabled" property="enabled"/>
        <result column="access_type" property="accessType"/>
        <result column="allowed_roles" property="allowedRoles"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryAll" resultMap="dataMap">
        select *
        from project
        order by sort_order asc, id desc
    </select>

    <select id="queryPublicList" resultMap="dataMap">
        select *
        from project
        where is_public = 1
        order by sort_order asc, id desc
    </select>

    <select id="queryById" parameterType="java.lang.Long" resultMap="dataMap">
        select *
        from project
        where id = #{id}
    </select>

    <insert id="insert" parameterType="cn.idealer01.infrastructure.dao.po.Project" useGeneratedKeys="true" keyProperty="id">
        insert into project(name, description, tech_stack, project_url, github_url, preview_url, cover_image, showcase_images, status, sort_order, start_date, end_date, is_public, enabled, access_type, allowed_roles)
        values (#{name}, #{description}, #{techStack}, #{projectUrl}, #{githubUrl}, #{previewUrl}, #{coverImage}, #{showcaseImages}, #{status}, #{sortOrder}, #{startDate}, #{endDate}, #{isPublic}, #{enabled}, #{accessType}, #{allowedRoles})
    </insert>

    <update id="update" parameterType="cn.idealer01.infrastructure.dao.po.Project">
        update project
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="techStack != null">tech_stack = #{techStack},</if>
            <if test="projectUrl != null">project_url = #{projectUrl},</if>
            <if test="githubUrl != null">github_url = #{githubUrl},</if>
            <if test="previewUrl != null">preview_url = #{previewUrl},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="showcaseImages != null">showcase_images = #{showcaseImages},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="isPublic != null">is_public = #{isPublic},</if>
            <if test="enabled != null">enabled = #{enabled},</if>
            <if test="accessType != null">access_type = #{accessType},</if>
            <if test="allowedRoles != null">allowed_roles = #{allowedRoles},</if>
            update_time = CURRENT_TIMESTAMP
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from project where id = #{id}
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.idealer01.infrastructure.dao.IMessageSettingsDao">

    <resultMap id="dataMap" type="cn.idealer01.infrastructure.dao.po.MessageSettingsRecord">
        <id column="id" property="id"/>
        <result column="review_mode" property="reviewMode"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryCurrent" resultMap="dataMap">
        select * from message_settings order by id asc limit 1
    </select>

    <insert id="insert" parameterType="cn.idealer01.infrastructure.dao.po.MessageSettingsRecord" useGeneratedKeys="true" keyProperty="id">
        insert into message_settings(review_mode)
        values (#{reviewMode})
    </insert>

    <update id="update" parameterType="cn.idealer01.infrastructure.dao.po.MessageSettingsRecord">
        update message_settings
        set review_mode = #{reviewMode}, update_time = CURRENT_TIMESTAMP
        where id = #{id}
    </update>

</mapper>

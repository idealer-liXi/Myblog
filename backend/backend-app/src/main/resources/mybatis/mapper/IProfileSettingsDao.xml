<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.idealer01.infrastructure.dao.IProfileSettingsDao">

    <resultMap id="dataMap" type="cn.idealer01.infrastructure.dao.po.ProfileSettingsRecord">
        <id column="id" property="id"/>
        <result column="avatar" property="avatar"/>
        <result column="name" property="name"/>
        <result column="bio" property="bio"/>
        <result column="email" property="email"/>
        <result column="github_name" property="githubName"/>
        <result column="github_url" property="githubUrl"/>
        <result column="location" property="location"/>
        <result column="introduction" property="introduction"/>
        <result column="hobbies" property="hobbies"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryCurrent" resultMap="dataMap">
        select * from profile_settings order by id asc limit 1
    </select>

    <insert id="insert" parameterType="cn.idealer01.infrastructure.dao.po.ProfileSettingsRecord" useGeneratedKeys="true" keyProperty="id">
        insert into profile_settings(avatar, name, bio, email, github_name, github_url, location, introduction, hobbies)
        values (#{avatar}, #{name}, #{bio}, #{email}, #{githubName}, #{githubUrl}, #{location}, #{introduction}, #{hobbies})
    </insert>

    <update id="update" parameterType="cn.idealer01.infrastructure.dao.po.ProfileSettingsRecord">
        update profile_settings
        set avatar = #{avatar},
            name = #{name},
            bio = #{bio},
            email = #{email},
            github_name = #{githubName},
            github_url = #{githubUrl},
            location = #{location},
            introduction = #{introduction},
            hobbies = #{hobbies},
            update_time = CURRENT_TIMESTAMP
        where id = #{id}
    </update>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.idealer01.infrastructure.dao.IThemeDao">

    <resultMap id="dataMap" type="cn.idealer01.infrastructure.dao.po.Theme">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="icon" property="icon"/>
        <result column="color" property="color"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="article_count" property="articleCount"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryAll" resultMap="dataMap">
        select t.*,
               (select count(*) from article a where a.theme = t.name) as article_count
        from theme t
        order by sort_order asc, id asc
    </select>

    <select id="queryById" parameterType="java.lang.Long" resultMap="dataMap">
        select t.*,
               (select count(*) from article a where a.theme = t.name) as article_count
        from theme t
        where t.id = #{id}
    </select>

    <select id="queryByName" parameterType="java.lang.String" resultMap="dataMap">
        select t.*,
               (select count(*) from article a where a.theme = t.name) as article_count
        from theme t
        where t.name = #{name}
    </select>

    <insert id="insert" parameterType="cn.idealer01.infrastructure.dao.po.Theme" useGeneratedKeys="true" keyProperty="id">
        insert into theme(name, icon, color, sort_order)
        values (#{name}, #{icon}, #{color}, #{sortOrder})
    </insert>

    <update id="update" parameterType="cn.idealer01.infrastructure.dao.po.Theme">
        update theme
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="color != null">color = #{color},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            update_time = CURRENT_TIMESTAMP
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from theme where id = #{id}
    </delete>

</mapper>

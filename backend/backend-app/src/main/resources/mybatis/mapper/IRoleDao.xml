<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="cn.idealer01.infrastructure.dao.IRoleDao">

    <resultMap id="dataMap" type="cn.idealer01.infrastructure.dao.po.Role">
        <id column="id" property="id"/>
        <result column="role_code" property="roleCode"/>
        <result column="role_name" property="roleName"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryRoleById" parameterType="java.lang.Long" resultMap="dataMap">
        select id, role_code, role_name, description, create_time, update_time
        from role
        where id = #{roleId};
    </select>

    <select id="queryRoleByCode" parameterType="java.lang.String" resultMap="dataMap">
        select id, role_code, role_name, description, create_time, update_time
        from role
        where role_code = #{roleCode};
    </select>

    <select id="queryRoleByUserId" parameterType="java.lang.Long" resultMap="dataMap">
        select r.id, r.role_code, r.role_name, r.description, r.create_time, r.update_time
        from role r
                 inner join user_role ur on r.id = ur.role_id
        where ur.user_id = #{userId}
        order by r.id asc
        limit 1;
    </select>

</mapper>
